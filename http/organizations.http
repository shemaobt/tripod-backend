@baseUrl = http://localhost:8000
# Set after running Auth: Login in auth.http
@accessToken =

### List organizations
GET {{baseUrl}}/api/organizations
Authorization: Bearer {{accessToken}}

### Create organization
POST {{baseUrl}}/api/organizations
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Acme Corp",
  "slug": "acme-corp"
}

### Get organization by slug
GET {{baseUrl}}/api/organizations/slug/acme-corp
Authorization: Bearer {{accessToken}}

### Get organization by id
GET {{baseUrl}}/api/organizations/ORGANIZATION_ID
Authorization: Bearer {{accessToken}}

### Update organization
PATCH {{baseUrl}}/api/organizations/ORGANIZATION_ID
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Acme Corporation",
  "slug": "acme-corporation"
}

### Add member to organization
POST {{baseUrl}}/api/organizations/ORGANIZATION_ID/members
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "user_id": "USER_ID",
  "role": "member"
}

### List organization members
GET {{baseUrl}}/api/organizations/ORGANIZATION_ID/members
Authorization: Bearer {{accessToken}}

### Remove member from organization
DELETE {{baseUrl}}/api/organizations/ORGANIZATION_ID/members/USER_ID
Authorization: Bearer {{accessToken}}
